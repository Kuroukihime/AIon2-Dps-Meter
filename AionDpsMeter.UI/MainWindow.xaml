<Window x:Class="AionDpsMeter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:AionDpsMeter.UI.ViewModels"
        mc:Ignorable="d"
        Title="AION2 DPS Meter"
        Height="170"
        Width="360"
        MinHeight="80"
        MinWidth="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="MainBorder"
            Background="#EB0D1117"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="0"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Global background image (behind everything, Style 1 only) -->
            <Image x:Name="PlayersBackgroundImage"
                   Grid.RowSpan="3"
                   Stretch="UniformToFill"
                   IsHitTestVisible="False"
                   Visibility="{Binding IsStyle1, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  STYLE 1 – Compact Header (original, unchanged)           -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="#CC0D1117"
                    CornerRadius="3,3,0,0"
                    Padding="6,4"
                    Visibility="{Binding IsStyle1, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#B321262D"
                            CornerRadius="3"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding CombatDuration}"
                                   FontSize="11" FontFamily="Consolas" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#B321262D"
                            CornerRadius="3" Padding="6,2" Margin="4,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding PingDisplay}"
                                   FontSize="10" FontFamily="Consolas" FontWeight="Bold"
                                   Foreground="{Binding PingColor, Converter={StaticResource StringToBrushConverter}}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="2" Margin="6,0" VerticalAlignment="Center"
                          Visibility="{Binding HasActiveTarget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ActiveTargetName}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveTargetHpDisplay}"
                                       FontSize="9" FontFamily="Consolas"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>
                        <Grid Grid.Row="1" Height="3" Margin="0,2,0,0"
                              Visibility="{Binding ActiveTargetHpTotal, Converter={StaticResource IntToVisibilityConverter}}">
                            <Border Background="{StaticResource PrimaryBackgroundBrush}" CornerRadius="2"/>
                            <Border Background="#C84040" CornerRadius="2" HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                        <Binding Path="ActiveTargetHpPercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </Grid>

                    <Button Grid.Column="3" Content="☰" Width="22" Height="22" FontSize="12"
                            Margin="2,0" ToolTip="History" Click="HistoryButton_Click"
                            Style="{StaticResource ModernButtonStyle}" Background="#B321262D" Padding="0"/>
                    <Button Grid.Column="4" Content="↺" Command="{Binding ResetDataCommand}"
                            Width="22" Height="22" FontSize="14" Margin="4,0" ToolTip="Reset"
                            Style="{StaticResource ModernButtonStyle}" Background="#B321262D" Padding="0"/>
                    <Button Grid.Column="5" Content="⚙" Width="22" Height="22" FontSize="12"
                            Margin="2,0" ToolTip="Settings" Click="SettingsButton_Click"
                            Style="{StaticResource ModernButtonStyle}" Background="#B321262D" Padding="0"/>
                    <Button Grid.Column="6" Content="━" Width="22" Height="22" FontSize="10"
                            Margin="2,0" Click="MinimizeButton_Click"
                            Style="{StaticResource ModernButtonStyle}" Background="#B321262D" Padding="0"/>
                    <Button Grid.Column="7" Content="✕" Width="22" Height="22" FontSize="10"
                            Click="CloseButton_Click"
                            Style="{StaticResource ModernButtonStyle}" Background="#B3C42B1C" Padding="0"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  STYLE 2 – Detailed Header                                  -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Margin="0,0,0,6"
                    Padding="8,6"
                    CornerRadius="4"
                    Background="#E615161A"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    Visibility="{Binding IsStyle2, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="2"/>
                    </Grid.RowDefinitions>

                    <!-- Top Row: Boss Name & Controls -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding ActiveTargetName}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Style 2 Ping & Timer -->
                            <TextBlock Text="{Binding PingDisplay}"
                                       FontSize="11" FontFamily="Consolas" FontWeight="Bold"
                                       Foreground="{Binding PingColor, Converter={StaticResource StringToBrushConverter}}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CombatDuration}"
                                       FontSize="11" FontFamily="Consolas" Foreground="#9BA1A6"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>

                            <!-- Style 2 Controls -->
                            <Button Content="☰" Width="18" Height="18" FontSize="10" Margin="1,0" ToolTip="History" Click="HistoryButton_Click" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#888" Padding="0"/>
                            <Button Content="↺" Command="{Binding ResetDataCommand}" Width="18" Height="18" FontSize="12" Margin="1,0" ToolTip="Reset" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#888" Padding="0"/>
                            <Button Content="⚙" Width="18" Height="18" FontSize="10" Margin="1,0" ToolTip="Settings" Click="SettingsButton_Click" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#888" Padding="0"/>
                            <Button Content="━" Width="18" Height="18" FontSize="8" Margin="1,0" Click="MinimizeButton_Click" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#888" Padding="0"/>
                            <Button Content="✕" Width="18" Height="18" FontSize="8" Margin="1,0,0,0" Click="CloseButton_Click" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#888" Padding="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Middle Row: HP Text & Total Damage -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveTargetHpDisplay}" FontSize="10" FontFamily="Consolas" Foreground="#D96464"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="{Binding TotalRaidDamageFormatted}"
                                   FontSize="14" FontWeight="Bold" Foreground="#52E0C4"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Bottom Row: Thin Red HP Bar -->
                    <Grid x:Name="Style2HpBarContainer"
                          Grid.Row="4"
                          Height="3"
                          Visibility="{Binding ActiveTargetHpTotal, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border x:Name="HpBarBackground" Background="#4D4D4D" CornerRadius="1"/>
                        <Border Background="#C84040" CornerRadius="1" HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                    <Binding Path="ActiveTargetHpPercentage"/>
                                    <Binding ElementName="Style2HpBarContainer" Path="ActualWidth"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Update Banner (shared, both styles)                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#1A2A1A" BorderBrush="#3A6B3A" BorderThickness="0,1,0,1"
                    Padding="8,4"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="6" Height="6" Fill="#4CAF50"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding UpdateVersionText}"
                               FontSize="10" Foreground="#A5D6A7"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2" Content="What's New" Height="18" FontSize="10"
                            Margin="6,0,4,0" Padding="6,0" Click="WhatsNewButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#1F4D1F" Foreground="#A5D6A7"/>
                    <Button Grid.Column="3" Content="✕" Width="18" Height="18" FontSize="9"
                            Padding="0" Command="{Binding DismissUpdateCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="Transparent" Foreground="#6A8F6A"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  Players List area                                         -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" ClipToBounds="True">

                <!-- Dark overlay for bg image (Style 1 only) -->
                <Border x:Name="PlayersBackgroundOverlay"
                        Background="#80000000"
                        IsHitTestVisible="False"
                        Visibility="Collapsed"/>

                <!-- ─────────────────────────────────────────────────────── -->
                <!--  STYLE 1 LIST – original compact rows (unchanged)       -->
                <!-- ─────────────────────────────────────────────────────── -->
                <ListBox ItemsSource="{Binding Players}"
                         Background="Transparent"
                         BorderThickness="0"
                         Grid.IsSharedSizeScope="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="4,1,4,2"
                         Visibility="{Binding IsStyle1, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Margin="0,0" Padding="0"
                                    Cursor="Hand" MouseLeftButtonDown="PlayerItem_Click">
                                <Border.Tag>
                                    <Binding/>
                                </Border.Tag>
                                <Grid>
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PlayerRowScale}"
                                                        ScaleY="{Binding PlayerRowScale}"/>
                                    </Grid.LayoutTransform>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition SharedSizeGroup="DpsCol" Width="Auto"/>
                                        <ColumnDefinition SharedSizeGroup="PctCol" Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="2"
                                            Background="#BF21262D" VerticalAlignment="Center">
                                        <Image Source="{Binding ClassIcon, Converter={StaticResource SafeImageSourceConverter}}"
                                               Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </Border>

                                    <Grid Grid.Column="1" Margin="4,2,4,2" VerticalAlignment="Center">
                                        <Border Background="{StaticResource TertiaryBackgroundBrush}"
                                                CornerRadius="2" Height="20" Opacity="0.4"/>
                                        <Border Background="{Binding IsUser, Converter={StaticResource BoolToProgressBrushConverter}}"
                                                CornerRadius="2" Height="20" Opacity="0.55"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                    <Binding Path="EffectivePercentage"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <Grid>
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left"
                                                        VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding PlayerNameDisplay}" FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CombatPower, StringFormat=CP: {0}}"
                                                           FontSize="8"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Visibility="{Binding CombatPower, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TotalDamageFormatted}" FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <Border Grid.Column="2" Background="#8C21262D" CornerRadius="2"
                                            Padding="4,2" Margin="0,2" VerticalAlignment="Center">
                                        <TextBlock FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource DpsColorBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding DpsFormatted, Mode=OneWay}"/>
                                            <Run Text="/s" FontSize="8" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DamagePercentage, StringFormat={}{0:F1}%}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" Margin="4,0,2,0"
                                               Width="36" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ─────────────────────────────────────────────────────── -->
                <!--  STYLE 2 LIST – Detailed Panel Rows                    -->
                <!-- ─────────────────────────────────────────────────────── -->
                <ListBox ItemsSource="{Binding Players}"
                         Background="Transparent"
                         BorderThickness="0"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="0"
                         Visibility="{Binding IsStyle2, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Cursor="Hand" MouseLeftButtonDown="PlayerItem_Click">
                                <Border.Tag>
                                    <Binding/>
                                </Border.Tag>
                                <Grid>
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PlayerRowScale}" ScaleY="{Binding PlayerRowScale}"/>
                                    </Grid.LayoutTransform>

                                    <!-- Row Wrapper -->
                                    <Border Margin="0,0,0,4" Background="#CC15161A" CornerRadius="4" BorderBrush="#22FFFFFF" BorderThickness="1" ClipToBounds="True">
                                        <Grid>

                                            <!-- Gradient Fill Bar (Spans full width so it sits under the transparent icon block) -->
                                            <Border HorizontalAlignment="Left"
                                                    Background="{Binding IsUser, Converter={StaticResource BoolToProgressBrushConverter}}"
                                                    Opacity="0.55">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                        <Binding Path="EffectivePercentage"/>
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>

                                            <!-- Content Grid overlaying the Fill Bar -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left side: Icon Block (Now fully transparent) -->
                                                <Border Grid.Column="0" Background="Transparent">
                                                    <Grid>

                                                        <!-- Center Class Icon -->
                                                        <Image Source="{Binding ClassIcon, Converter={StaticResource SafeImageSourceConverter}}"
                                                               Width="35" Height="35" VerticalAlignment="Center" Margin="0,-4,0,0" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>

                                                        <!-- Combat Power at the bottom -->
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,3" Visibility="{Binding CombatPower, Converter={StaticResource StringToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding CombatPower}" FontSize="10" Foreground="#FFFFFF" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Right side: Stats Block -->
                                                <Grid Grid.Column="1" Margin="8,5,8,5">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Top Left: Player Name -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding PlayerNameDisplay}"
                                                               FontSize="11" FontWeight="Bold" Foreground="White"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <!-- Bottom Left: CRIT Stat -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="CRIT " FontSize="9" Foreground="#7A8085" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding CriticalRate, StringFormat={}{0:F1}%}" FontSize="9" Foreground="#9BA1A6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    </StackPanel>

                                                    <!-- Top Right: DPS and Percent -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DpsFormatted, StringFormat={}{0:F1}/s}" FontSize="11" FontWeight="Bold" Foreground="#E0E0E0" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding DamagePercentage, StringFormat={}{0:F1}%}" FontSize="11" FontWeight="Bold" Foreground="White" Width="38" TextAlignment="Right"/>
                                                    </StackPanel>

                                                    <!-- Bottom Right: Total Damage -->
                                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                                               Text="{Binding TotalDamageFormatted}"
                                                               FontSize="10" FontWeight="SemiBold" Foreground="#9BA1A6"
                                                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Grid>
    </Border>
</Window>