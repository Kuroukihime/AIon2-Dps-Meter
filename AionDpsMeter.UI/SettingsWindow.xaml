<Window x:Class="AionDpsMeter.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="400"
        Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="#30363D"
                                    CornerRadius="10"
                                    Width="40"
                                    Height="20"/>
                            <Ellipse x:Name="Thumb"
                                     Width="14"
                                     Height="14"
                                     Fill="#8B949E"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#1F6FEB"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#E6EDF3"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PrimaryBackgroundBrush}"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Opacity="0.95">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="3,3,0,0"
                    Padding="8,5">
                <Grid>
                    <TextBlock Text="Settings"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            Width="22"
                            Height="22"
                            FontSize="10"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#C42B1C"
                            Padding="0"/>
                </Grid>
            </Border>

            <!-- Settings content -->
            <Border Grid.Row="1" Padding="12,12">
                <StackPanel VerticalAlignment="Top">

                <!-- Raw Packet Logging row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Raw Packet Logging"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Save packets to PacketLogs folder"
                                   FontSize="10"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <ToggleButton Grid.Column="1"
                                  IsChecked="{Binding IsPacketLoggingEnabled, Mode=TwoWay}"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"/>
                </Grid>

                <!-- Nickname hiding row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Hide Nicknames"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Mask player names for screenshots"
                                   FontSize="10"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <ToggleButton Grid.Column="1"
                                  IsChecked="{Binding IsNicknameHidden, Mode=TwoWay}"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"/>
                </Grid>

                <!-- History damage threshold row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="History Damage Threshold"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Hide sessions with total damage below this"
                                   FontSize="10"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Width="80"
                             Text="{Binding HistoryDamageThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Right"
                             Margin="12,0,0,0"
                             Padding="4,2"
                             FontSize="11"
                             MaxLength="10"
                             Background="#21262D"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             BorderBrush="#30363D"
                             BorderThickness="1"
                             CaretBrush="{StaticResource PrimaryTextBrush}"
                             PreviewTextInput="ThresholdTextBox_PreviewTextInput"/>
                </Grid>

                <!-- Window Opacity row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Window Opacity"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Transparency of the main window (10%–100%)"
                                   FontSize="10"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Slider Minimum="10" Maximum="100"
                                Value="{Binding WindowOpacityPercent, Mode=TwoWay}"
                                Width="100"
                                VerticalAlignment="Center"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"/>
                        <TextBlock Text="{Binding WindowOpacityPercent, StringFormat={}{0}%}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Width="36"/>
                    </StackPanel>
                </Grid>

                <!-- Background Image row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Background Image"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding BackgroundImagePath, TargetNullValue='Default (none)'}"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="200"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Content="Browse"
                                Command="{Binding PickBackgroundImageCommand}"
                                Width="60"
                                Height="22"
                                FontSize="10"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="{StaticResource TertiaryBackgroundBrush}"
                                Padding="4,0"/>
                        <Button Content="✕"
                                Command="{Binding ResetBackgroundImageCommand}"
                                Width="22"
                                Height="22"
                                FontSize="10"
                                Margin="4,0,0,0"
                                ToolTip="Reset to default"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#C42B1C"
                                Padding="0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
